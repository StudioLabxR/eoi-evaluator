{
  "name": "nmm-eoi-evaluator",
  "productName": "NMM EOI Evaluator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:3000 && cross-env VITE_DEV_SERVER_URL=http://localhost:3000 electron .\"",
    "dist:mac": "vite build && electron-builder --mac && codesign --force --deep --sign - release/mac-arm64/NMM\\ EOI\\ Evaluator.app && xattr -cr release/mac-arm64/NMM\\ EOI\\ Evaluator.app",
    "install:mac": "cp -R release/mac-arm64/NMM\\ EOI\\ Evaluator.app /Applications/ && xattr -cr /Applications/NMM\\ EOI\\ Evaluator.app && codesign --force --deep --sign - /Applications/NMM\\ EOI\\ Evaluator.app",
    "dist:win": "vite build && electron-builder --win --x64",
    "dist:linux": "vite build && electron-builder --linux --arm64",
    "dist:all": "vite build && electron-builder --mac --win --x64 --linux --arm64"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "docx": "^9.6.0",
    "file-saver": "^2.0.5",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.nmm.eoi-evaluator",
    "productName": "NMM EOI Evaluator",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business",
      "identity": "-",
      "notarize": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}
